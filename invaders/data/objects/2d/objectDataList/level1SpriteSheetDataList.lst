<?xml version="1.0"?>
<objectDataList2D>

    <!-- DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT -->
    <default name="">
        <visual>
            <texture file="data/textures/level/level1_spriteSheet.png" filter="NEAREST"/>
            <mesh genType="sprite_sheet">
                <spriteSheet file="data/objects/2d/mesh/level/level1.xml"/>
            </mesh>
            <shader id="shader_2d_spriteSheet"/>
            <color r="1" g="1" b="1" a="1"/>
        </visual>
    </default>
    <!-- DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT DEFAULT -->

    <objectList>

        <object name="progress_frame">
            <visual>
                <mesh genType="scaled_frame">
                    <spriteSheet>
                        <glyph id="8x8_1_pixel_frame"/>
