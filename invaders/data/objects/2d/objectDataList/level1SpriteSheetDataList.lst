                    <scaledFrame thicknessWidth="3" thicknessHeight="3" centerQuad="true"/>
                </mesh>
                <shader id="shader_2d"/>
                <color r="0" g="0" b="0" a="1"/>
            </visual>
            <size width="60" height="8"/>
        </object>

        <object name="progress_solid">
