            </visual>
            <collision filterCategoryBits="0x00000001" filterMaskBits="0x00000000" collisionSignal="true">
                <!--<circle radiusFromVisual="true"/>-->
                <!--<rect radiusFromVisual="true" rectFromVisual="true"/>-->
                <pointList radiusFromVisual="true">
